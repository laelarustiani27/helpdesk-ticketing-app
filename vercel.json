{
    "version": 2,
    "framework": null,
    "build": {
        "env": {
            "APP_ENV": "production"
        }
    },
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.2"
        }
    },
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ]
}